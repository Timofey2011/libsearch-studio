{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibSearch Studio",
  "version": "0.8.0",
  "identifier": "com.libsearch.studio",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../frontend dev",
    "beforeBuildCommand": "pnpm --dir ../frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "LibSearch Studio",
        "width": 1180,
        "height": 780,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb"],
    "category": "Productivity",
    "shortDescription": "Chat with your library, grounded in your books.",
    "longDescription": "LibSearch Studio is a local-first desktop app for chatting with a local LLM grounded in your personal PDF library, with clickable citations that open the source at the cited page.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
